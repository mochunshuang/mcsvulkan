If: # 收集信息的范围
  PathMatch: [include/.*,src/.*,test/.*,example/.*,config/.*] # to all headers...
  PathExclude: [include/llvm-c/.*,plugin/.*] # except those under include/llvm-c/

CompileFlags: # Tweak the parse settings
  # List of flags to append to the compile command.d
  Add: [
     -Wall,-Wno-missing-braces,-std=c++26
    # ,-std=gnu++20
  ] # treat all files as C++, enable more warnings
  # Remove: -W* # strip all other warning-related flags
  # 全局移除编译参数:Clangd 无法解析的命令参数如下：
  Remove: 
  [
    -fmodules-ts,
    -fdeps-format=p1689r5,
    -fmodule-mapper*,-freflection
  ]
  # 看起来.clangd 优先级最高. 两个一起配置：--query-driver=E:/mysoftware/gcc-v16.1.0-mingw-v14.0.0-ucrt-x86_64/bin/g++.exe
  # Compiler: clang++               # Change argv[0] of compile flags to `clang++`
  Compiler: E:/mysoftware/gcc-v16.1.0-mingw-v14.0.0-ucrt-x86_64/bin/g++.exe



Diagnostics:
  ClangTidy:
    Add: [cppcoreguidelines-*,google-*,misc-*,performance-*,bugprone-*,portability-*,hicpp-*,readability-*,modernize-*,portability-*,clang-analyzer-*,concurrency-*,cert-*]
    Remove: 
    [
      modernize-use-trailing-return-type,
      # 允许不用{}包裹语句
      readability-braces-around-statements,google-readability-braces-around-statements,hicpp-braces-around-statements,
      # 使用goto
      cppcoreguidelines-avoid-goto,hicpp-avoid-goto,
      # 允许if里面赋值
      bugprone-assignment-in-if-condition,
      # 没有gsl::owner<T*>
      cppcoreguidelines-owning-memory,
      # 使用指针算数
      cppcoreguidelines-pro-bounds-pointer-arithmetic,
      # 使用裸数组指针，因为是C库，无法避免
      cppcoreguidelines-pro-bounds-array-to-pointer-decay,hicpp-no-array-decay,
      # 允许默认参数的函数调用
      fuchsia-default-arguments-calls,fuchsia-default-arguments-declarations,
      # for 带变量是正常的
      altera-unroll-loops,
      # 允许位运算
      hicpp-signed-bitwise,
      # 允许双下划线开头
      cert-dcl37-c,bugprone-reserved-identifier,cert-dcl51-cpp,
      # 避免[] 数组警告
      cppcoreguidelines-pro-bounds-constant-array-index
    ]
    CheckOptions:
      readability-identifier-length.MinimumParameterNameLength: 1
      readability-identifier-length.MinimumVariableNameLength: 1 #变量的长度限制激活，默认至少3各字符
      readability-identifier-naming.VariableCase: camelBack,lower_case
      readability-identifier-naming.GlobalVariableCase: lower_case
      readability-identifier-naming.GlobalVariablePrefix: g_
      readability-identifier-naming.PrivateMemberSuffix: _
      # ui 例外
      readability-identifier-naming.PrivateMemberIgnoredRegexp: ^ui,
      # 函数名
      readability-identifier-naming.ProtectedMemberPrefix: m_
      # 结构体成员下划线
      readability-identifier-naming.PublicMemberCase: lower_case
      readability-identifier-naming.ProtectedMemberCase: camelBack
      readability-identifier-naming.PrivateMemberCase: camelBack
      readability-identifier-naming.ClassMemberPrefix: m_
      readability-identifier-naming.ValueTemplateParameterSuffix.VariableHungarianPrefix: _
      # 常量
      readability-identifier-naming.ConstantCase: UPPER_CASE
      # readability-identifier-naming.ConstantPrefix: k_
      readability-identifier-naming.EnumCase: UPPER_CASE,lower_case
      readability-identifier-naming.EnumConstantCase: UPPER_CASE
      readability-identifier-naming.EnumConstantPrefix: e
      # 宏定义
      readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
      # 类
      readability-identifier-naming.ClassCase: CamelCase
      readability-identifier-naming.StructCase: lower_case
      # 函数方法
      readability-identifier-naming.FunctionCase: lower_case
      readability-identifier-naming.ClassMethodCase: camelBack
      readability-identifier-naming.MethodCase: camelBack
      # 概念
      readability-identifier-naming.ConceptCase: lower_case
      # readability-identifier-naming.ConceptPrefix: is_
      # 函数名忽略
      readability-identifier-naming.MethodIgnoredRegexp: "^(signal_|slots_).*"
      # 结构体名忽略
      readability-identifier-naming.StructIgnoredRegexp: "(__.*|.*_t)"
      # 库例外
      readability-identifier-naming.GlobalFunctionIgnoredRegexp: "^__.*"
      # 命名空间
      readability-identifier-naming.NamespaceCase: 'lower_case'
  Suppress:
    # 反射语法导致的常见误报
    - typename_requires_specqual
    - blocks_disable
    - nonfunction_block_type
    - expected_expression
    # 如果还有其他，可以继续追加. 全部来自clangd的提示
    - expected_namespace_name
    - undeclared_var_use   # 或者 err_undeclared_var_use（任选一个）
    - static_assert_expression_is_not_constant
    - ovl_no_viable_function_in_call
    - expected_qualified_after_typename
    - missing_type_specifier
    - expected_type
    - expected_unqualified_id
    - no_member
    - undeclared_var_use_suggest
    - expr_not_cce
    - expected_less_after
    - expected_member_name_or_semi
    - mem_init_not_member_or_class
    - auto_var_requires_init
    - typecheck_decl_incomplete_type
    - constexpr_var_non_literal
    - template_instantiate_undefined
    - implicit_instantiate_member_undefined
    - expected
    - constexpr_var_requires_const_init
    - missing_param
    - expected_capture
    - unknown_typename
    - no_member_suggest
    - typename_nested_not_found
    - invalid_non_static_member_use
    - fatal_too_many_errors
      
  UnusedIncludes: Strict
  MissingIncludes: None
  Includes:
    IgnoreHeader: Python\.h

# https://clangd.llvm.org/config#index
Index:
  StandardLibrary: true
  Background: Build
  # Background: Skip     # Disable slow background indexing of these files.

# https://clangd.llvm.org/config#completion
Completion:
  AllScopes: Yes
  ArgumentLists: FullPlaceholders
  HeaderInsertion: IWYU  # IWYU 或 Never 禁用自动头文件插入
  CodePatterns: All

InlayHints:
  BlockEnd: false
  Designators: true
  Enabled: true
  ParameterNames: true
  DeducedTypes: true
  DefaultArguments: false
  TypeNameLimit: 24
# 悬停卡
Hover:
  ShowAKA: No

# 配置语义高亮
SemanticTokens:
  DisabledKinds: []
  DisabledModifiers: []